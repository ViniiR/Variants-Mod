{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"Vinii"
	],
	"contact": {
		"homepage": "https://github.com/ViniiR/Variants-Mod",
		"sources": "https://github.com/ViniiR/Variants-Mod"
	},
	"license": "${mod_license}",
	"icon": "assets/v2m/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.vinii.v2m.ViniisVariantsMod"
		],
		"client": [
			"com.vinii.v2m.client.ViniisVariantsModClient"
		],
		"fabric-datagen": [
			"com.vinii.v2m.datagen.ViniisVariantsModDataGenerator"
		]
	},
	"accessWidener": "${mod_id}.accesswidener",
	"mixins": [
      "${mod_id}.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${fabric_loader_version}",
		"minecraft": ">=${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": ">=${fabric_api_version}"
	}
}